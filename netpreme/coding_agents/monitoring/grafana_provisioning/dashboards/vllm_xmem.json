      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(vllm:prompt_tokens_by_source_total{source='local_cache_hit',model_name=\"$model_name\"}[$__rate_interval])",
          "legendFormat": "cached (from KV cache)",
          "refId": "A"
