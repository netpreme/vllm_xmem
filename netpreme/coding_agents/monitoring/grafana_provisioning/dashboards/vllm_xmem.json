          "legendFormat": "computed (GPU prefill)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(vllm:prompt_tokens_by_source_total{source='external_kv_transfer',model_name=\"$model_name\"}[$__rate_interval])",
          "legendFormat": "offloaded (CPU/MTier recall)",
          "refId": "C"
        }
